# Neon PostgreSQL (https://neon.tech) — required on Vercel
DATABASE_URL="postgresql://user:password@host/db?sslmode=require"

# Auth.js — generate with: openssl rand -base64 32
AUTH_SECRET="your-secret-here"
NEXTAUTH_URL="http://localhost:3000"

# CRM toolbar link (admin/manager header)
# NEXT_PUBLIC_CRM_URL=http://localhost:3000

# Inbound CRM employee sync (server only — CRM pushes users here)
# INTEGRATION_API_KEY=shared-secret-or-lms-generated-key

# Stable Server Action IDs across builds (required on Vercel — generate once: openssl rand -base64 32)
NEXT_SERVER_ACTIONS_ENCRYPTION_KEY=""

# First deploy: run locally — npm run db:seed:production (uses .env.local)
ADMIN_EMAIL="admin@stormsprinklers.com"
ADMIN_INITIAL_PASSWORD="choose-a-strong-password"

# Mux video (https://mux.com) — optional for local dev
MUX_TOKEN_ID=""
MUX_TOKEN_SECRET=""
MUX_WEBHOOK_SECRET=""

# Vercel Blob — required for Library uploads, AI Studio sources, and PDF manuals
# Create a store in Vercel → Storage, connect to this project (auto-adds the token).
# Local dev: copy BLOB_READ_WRITE_TOKEN from Vercel env vars into this file.
BLOB_READ_WRITE_TOKEN=""

# OpenAI — AI Studio course generation and Whisper transcription
# Default model is gpt-4o-mini (higher TPM limits). Override for quality if your org tier allows:
# OPENAI_COURSE_MODEL="gpt-4o"
OPENAI_API_KEY=""

# Google Cloud — AI Studio auto image + YouTube search (enable YouTube Data API + Custom Search API)
# Image search also requires a Programmable Search Engine ID: https://programmablesearchengine.google.com/
GOOGLE_CLOUD_API_KEY=""
GOOGLE_CSE_ID=""
# Optional model overrides
# OPENAI_COURSE_MODEL="gpt-4o"
# OPENAI_SUMMARY_MODEL="gpt-4o-mini"
