# Neon PostgreSQL (https://neon.tech) — required on Vercel
# Use the *pooler* connection for the app (runtime):
DATABASE_URL="postgresql://user:password@ep-xxx-pooler.region.aws.neon.tech/db?sslmode=require"
# Use the *direct* connection for Prisma migrations (Vercel build). On Vercel, set this explicitly.
# If omitted locally, vercel-build derives it by removing "-pooler" from DATABASE_URL.
DIRECT_DATABASE_URL="postgresql://user:password@ep-xxx.region.aws.neon.tech/db?sslmode=require"

# Auth.js — generate with: openssl rand -base64 32
AUTH_SECRET="your-secret-here"
NEXTAUTH_URL="http://localhost:3000"

# First deploy only: admin account created automatically during Vercel build
ADMIN_EMAIL="admin@stormsprinklers.com"
ADMIN_INITIAL_PASSWORD="choose-a-strong-password"

# Mux video (https://mux.com) — optional for local dev
MUX_TOKEN_ID=""
MUX_TOKEN_SECRET=""
MUX_WEBHOOK_SECRET=""

# Vercel Blob — optional for PDF uploads
BLOB_READ_WRITE_TOKEN=""
