# Neon PostgreSQL (https://neon.tech) — required on Vercel
DATABASE_URL="postgresql://user:password@host/db?sslmode=require"

# Auth.js — generate with: openssl rand -base64 32
AUTH_SECRET="your-secret-here"
NEXTAUTH_URL="http://localhost:3000"

# Stable Server Action IDs across builds (required on Vercel — generate once: openssl rand -base64 32)
NEXT_SERVER_ACTIONS_ENCRYPTION_KEY=""

# First deploy: run locally — npm run db:seed:production (uses .env.local)
ADMIN_EMAIL="admin@stormsprinklers.com"
ADMIN_INITIAL_PASSWORD="choose-a-strong-password"

# Mux video (https://mux.com) — optional for local dev
MUX_TOKEN_ID=""
MUX_TOKEN_SECRET=""
MUX_WEBHOOK_SECRET=""

# Vercel Blob — required for Library uploads, AI Studio sources, and PDF manuals
# Create a store in Vercel → Storage, connect to this project (auto-adds the token).
# Local dev: copy BLOB_READ_WRITE_TOKEN from Vercel env vars into this file.
BLOB_READ_WRITE_TOKEN=""

# OpenAI — AI Studio course generation and Whisper transcription
OPENAI_API_KEY=""

# YouTube Data API — optional; improves AI Studio “find related YouTube videos” search
# https://console.cloud.google.com/apis/library/youtube.googleapis.com
YOUTUBE_API_KEY=""

# Optional — AI Studio auto image search for lessons (Wikimedia works without keys)
UNSPLASH_ACCESS_KEY=""
PEXELS_API_KEY=""
# Optional model overrides
# OPENAI_COURSE_MODEL="gpt-4o"
# OPENAI_SUMMARY_MODEL="gpt-4o-mini"
