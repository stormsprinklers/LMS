generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum UserRole {
  EMPLOYEE
  ADMIN
  COURSE_ADMIN
}

enum UserStatus {
  INVITED
  ACTIVE
  DISABLED
}

enum LessonType {
  VIDEO
  MANUAL
  EXAM
}

enum LessonProgressStatus {
  NOT_STARTED
  IN_PROGRESS
  COMPLETED
}

enum ExamAttemptStatus {
  IN_PROGRESS
  SUBMITTED_PENDING_GRADE
  PASSED
  FAILED
}

enum CertificationStatus {
  EARNED
  IN_PROGRESS
  EXPIRED
}

enum QuestionType {
  MULTIPLE_CHOICE
  MULTIPLE_SELECT
  FREE_RESPONSE
  SLIDER
  MATCHING
}

enum GradeVisibility {
  ADMIN_ONLY
  LEARNER_VISIBLE
}

enum GradingTaskStatus {
  PENDING
  COMPLETED
}

enum NotificationType {
  FREE_RESPONSE_TO_GRADE
  GRADES_PUBLISHED
}

model User {
  id            String     @id @default(cuid())
  email         String     @unique
  passwordHash  String?
  name          String?
  role          UserRole   @default(EMPLOYEE)
  status        UserStatus @default(INVITED)
  jobRole       String?
  createdAt     DateTime   @default(now())
  updatedAt     DateTime   @updatedAt

  accounts           Account[]
  sessions           Session[]
  invitesCreated     Invite[]         @relation("InviteCreator")
  enrollments        Enrollment[]
  lessonProgress     LessonProgress[]
  examAttempts       ExamAttempt[]
  certifications     Certification[]
  examsCreated       Exam[]           @relation("ExamCreator")
  courseAdmins       CourseAdmin[]
  examAssignments    ExamAssignment[]
  examGraders        ExamGrader[]
  examAnswersGraded  ExamAnswer[]     @relation("GradedBy")
  gradingTasks       GradingTask[]    @relation("GradingAssignee")
  notifications      Notification[]
}

model Account {
  id                String  @id @default(cuid())
  userId            String
  type              String
  provider          String
  providerAccountId String
  refresh_token     String? @db.Text
  access_token      String? @db.Text
  expires_at        Int?
  token_type        String?
  scope             String?
  id_token          String? @db.Text
  session_state     String?

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([provider, providerAccountId])
}

model Session {
  id           String   @id @default(cuid())
  sessionToken String   @unique
  userId       String
  expires      DateTime
  user         User     @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model VerificationToken {
  identifier String
  token      String   @unique
  expires    DateTime

  @@unique([identifier, token])
}

model Invite {
  id          String    @id @default(cuid())
  email       String
  token       String    @unique
  expiresAt   DateTime
  usedAt      DateTime?
  createdAt   DateTime  @default(now())
  createdById String?
  createdBy   User?     @relation("InviteCreator", fields: [createdById], references: [id])
}

model Course {
  id              String   @id @default(cuid())
  slug            String   @unique
  title           String
  description     String   @db.Text
  category        String
  estimatedHours  Float
  requiredRoles   String[] @default([])
  published       Boolean  @default(true)
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  modules            Module[]
  enrollments        Enrollment[]
  certificationRules CertificationRule[]
  courseAssignments  CourseAssignment[]
  courseAdmins       CourseAdmin[]
  exams              Exam[]
}

model CourseAdmin {
  id        String   @id @default(cuid())
  userId    String
  courseId  String
  createdAt DateTime @default(now())
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  course    Course   @relation(fields: [courseId], references: [id], onDelete: Cascade)

  @@unique([userId, courseId])
}

model CourseAssignment {
  id       String  @id @default(cuid())
  courseId String
  jobRole  String?
  course   Course  @relation(fields: [courseId], references: [id], onDelete: Cascade)

  @@unique([courseId, jobRole])
}

model Module {
  id        String   @id @default(cuid())
  courseId  String
  title     String
  sortOrder Int      @default(0)
  course    Course   @relation(fields: [courseId], references: [id], onDelete: Cascade)
  lessons   Lesson[]
}

model Lesson {
  id              String     @id @default(cuid())
  moduleId        String
  slug            String
  title           String
  type            LessonType
  sortOrder       Int        @default(0)
  durationMinutes Int?
  module          Module     @relation(fields: [moduleId], references: [id], onDelete: Cascade)
  videoAsset      VideoAsset?
  manualAsset     ManualAsset?
  exam            Exam?
  progress        LessonProgress[]

  @@unique([moduleId, slug])
}

model VideoAsset {
  id              String   @id @default(cuid())
  lessonId        String   @unique
  muxAssetId      String?
  muxPlaybackId   String?
  durationSeconds Int?
  status          String   @default("pending")
  lesson          Lesson   @relation(fields: [lessonId], references: [id], onDelete: Cascade)
}

model ManualAsset {
  id        String   @id @default(cuid())
  lessonId  String?  @unique
  title     String
  category  String
  version   String
  blobUrl   String?
  filename  String?
  pageCount Int      @default(0)
  updatedAt DateTime @default(now())
  lesson    Lesson?  @relation(fields: [lessonId], references: [id], onDelete: SetNull)
}

model Enrollment {
  id        String   @id @default(cuid())
  userId    String
  courseId  String
  createdAt DateTime @default(now())
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  course    Course   @relation(fields: [courseId], references: [id], onDelete: Cascade)

  @@unique([userId, courseId])
}

model LessonProgress {
  id              String               @id @default(cuid())
  userId          String
  lessonId        String
  status          LessonProgressStatus @default(NOT_STARTED)
  watchedSeconds  Int                  @default(0)
  updatedAt       DateTime             @updatedAt
  user            User                 @relation(fields: [userId], references: [id], onDelete: Cascade)
  lesson          Lesson               @relation(fields: [lessonId], references: [id], onDelete: Cascade)

  @@unique([userId, lessonId])
}

model Exam {
  id                String          @id @default(cuid())
  title             String
  description       String?         @db.Text
  lessonId          String?         @unique
  courseId          String?
  createdById       String?
  passingScore      Int
  timeLimitMinutes  Int
  attemptsAllowed   Int             @default(3)
  shuffleQuestions  Boolean         @default(false)
  published         Boolean         @default(true)
  archived          Boolean         @default(false)
  archivedAt        DateTime?
  gradeVisibility   GradeVisibility @default(ADMIN_ONLY)
  gradesPublishedAt DateTime?
  createdAt         DateTime        @default(now())
  updatedAt         DateTime        @updatedAt

  lesson      Lesson?          @relation(fields: [lessonId], references: [id], onDelete: Cascade)
  course      Course?          @relation(fields: [courseId], references: [id], onDelete: SetNull)
  createdBy   User?            @relation("ExamCreator", fields: [createdById], references: [id])
  questions   Question[]
  attempts    ExamAttempt[]
  assignments ExamAssignment[]
  graders     ExamGrader[]
}

model ExamAssignment {
  id        String   @id @default(cuid())
  examId    String
  userId    String
  createdAt DateTime @default(now())
  exam      Exam     @relation(fields: [examId], references: [id], onDelete: Cascade)
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([examId, userId])
}

model ExamGrader {
  id        String   @id @default(cuid())
  examId    String
  userId    String
  createdAt DateTime @default(now())
  exam      Exam     @relation(fields: [examId], references: [id], onDelete: Cascade)
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([examId, userId])
}

model Question {
  id        String       @id @default(cuid())
  examId    String
  type      QuestionType @default(MULTIPLE_CHOICE)
  text      String       @db.Text
  sortOrder Int          @default(0)
  config    Json?
  exam      Exam         @relation(fields: [examId], references: [id], onDelete: Cascade)
  options   AnswerOption[]
  answers   ExamAnswer[]
  gradingTasks GradingTask[]
}

model AnswerOption {
  id         String   @id @default(cuid())
  questionId String
  text       String
  isCorrect  Boolean  @default(false)
  sortOrder  Int      @default(0)
  question   Question @relation(fields: [questionId], references: [id], onDelete: Cascade)
}

model ExamAttempt {
  id                  String            @id @default(cuid())
  userId              String
  examId              String
  score               Int?
  passed              Boolean?
  status              ExamAttemptStatus @default(IN_PROGRESS)
  pendingManualGrade  Boolean           @default(false)
  questionOrder       Json?
  startedAt           DateTime          @default(now())
  completedAt         DateTime?
  answers             Json?
  user                User              @relation(fields: [userId], references: [id], onDelete: Cascade)
  exam                Exam              @relation(fields: [examId], references: [id], onDelete: Cascade)
  examAnswers         ExamAnswer[]
  gradingTasks        GradingTask[]
}

model ExamAnswer {
  id           String    @id @default(cuid())
  attemptId    String
  questionId   String
  value        Json
  autoScore    Float?
  manualScore  Float?
  feedback     String?   @db.Text
  gradedById   String?
  gradedAt     DateTime?
  attempt      ExamAttempt @relation(fields: [attemptId], references: [id], onDelete: Cascade)
  question     Question    @relation(fields: [questionId], references: [id], onDelete: Cascade)
  gradedBy     User?       @relation("GradedBy", fields: [gradedById], references: [id])

  @@unique([attemptId, questionId])
}

model GradingTask {
  id               String            @id @default(cuid())
  attemptId        String
  questionId       String
  courseId         String?
  status           GradingTaskStatus @default(PENDING)
  assignedToUserId String?
  createdAt        DateTime          @default(now())
  completedAt      DateTime?
  attempt          ExamAttempt       @relation(fields: [attemptId], references: [id], onDelete: Cascade)
  question         Question          @relation(fields: [questionId], references: [id], onDelete: Cascade)
  assignedTo       User?             @relation("GradingAssignee", fields: [assignedToUserId], references: [id])

  @@unique([attemptId, questionId])
}

model Notification {
  id        String           @id @default(cuid())
  userId    String
  type      NotificationType
  title     String
  body      String           @db.Text
  link      String?
  readAt    DateTime?
  metadata  Json?
  createdAt DateTime         @default(now())
  user      User             @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model CertificationRule {
  id             String          @id @default(cuid())
  courseId       String
  title          String
  validityMonths Int             @default(12)
  course         Course          @relation(fields: [courseId], references: [id], onDelete: Cascade)
  certifications Certification[]
}

model Certification {
  id        String              @id @default(cuid())
  userId    String
  ruleId    String
  title     String
  status    CertificationStatus @default(IN_PROGRESS)
  issuedAt  DateTime?
  expiresAt DateTime?
  user      User                @relation(fields: [userId], references: [id], onDelete: Cascade)
  rule      CertificationRule   @relation(fields: [ruleId], references: [id], onDelete: Cascade)

  @@unique([userId, ruleId])
}
