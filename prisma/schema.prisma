generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum UserRole {
  EMPLOYEE
  MANAGER
  ADMIN
  COURSE_ADMIN
}

enum UserStatus {
  INVITED
  ACTIVE
  DISABLED
}

enum LessonType {
  VIDEO
  MANUAL
  EXAM
}

enum CourseStatus {
  DRAFT
  PUBLISHED
  ARCHIVED
}

enum CourseDifficulty {
  BEGINNER
  INTERMEDIATE
  ADVANCED
}

enum ContentStatus {
  DRAFT
  READY
  PUBLISHED
  ARCHIVED
}

enum CourseItemType {
  LESSON
  VIDEO
  QUIZ
  EXAM
  SKILL_CHECK
  SCENARIO
}

enum CourseItemTrack {
  LEARN
  PRACTICE
  PROVE
}

enum ModuleUnlockRule {
  ALWAYS
  PREVIOUS_MODULE_COMPLETE
  QUIZ_PASSED
  MANUAL
}

enum CourseVisibility {
  PRIVATE
  UNLISTED
  PUBLIC
}

enum EnrollmentMode {
  MANUAL
  AUTO
  SELF_ENROLL
}

enum CourseDueDateType {
  NONE
  RELATIVE
  FIXED
}

enum AssignToType {
  USER
  ROLE
  ALL
}

enum SkillCheckPassingRule {
  ALL_REQUIRED
  MINIMUM_SCORE
}

enum LessonProgressStatus {
  NOT_STARTED
  IN_PROGRESS
  COMPLETED
}

enum ExamAttemptStatus {
  IN_PROGRESS
  SUBMITTED_PENDING_GRADE
  PASSED
  FAILED
}

enum CertificationStatus {
  EARNED
  IN_PROGRESS
  EXPIRED
}

enum QuestionType {
  MULTIPLE_CHOICE
  MULTIPLE_SELECT
  FREE_RESPONSE
  SLIDER
  MATCHING
}

enum GradeVisibility {
  ADMIN_ONLY
  LEARNER_VISIBLE
}

enum GradingTaskStatus {
  PENDING
  COMPLETED
}

enum NotificationType {
  FREE_RESPONSE_TO_GRADE
  GRADES_PUBLISHED
}

model User {
  id            String     @id @default(cuid())
  email         String     @unique
  passwordHash  String?
  name          String?
  role          UserRole   @default(EMPLOYEE)
  status        UserStatus @default(INVITED)
  jobRole       String?
  archived      Boolean    @default(false)
  archivedAt    DateTime?
  createdAt     DateTime   @default(now())
  updatedAt     DateTime   @updatedAt

  accounts           Account[]
  sessions           Session[]
  invitesCreated     Invite[]         @relation("InviteCreator")
  enrollments        Enrollment[]
  lessonProgress     LessonProgress[]
  examAttempts       ExamAttempt[]
  certifications     Certification[]
  examsCreated       Exam[]           @relation("ExamCreator")
  courseAdmins       CourseAdmin[]
  examAssignments    ExamAssignment[]
  examGraders        ExamGrader[]
  examAnswersGraded  ExamAnswer[]     @relation("GradedBy")
  gradingTasks       GradingTask[]    @relation("GradingAssignee")
  notifications      Notification[]
  coursesCreated     Course[]         @relation("CourseCreator")
  courseItemProgress CourseItemProgress[]
  skillCheckCompletions     SkillCheckCompletion[]
  skillCheckEvaluations     SkillCheckCompletion[] @relation("SkillCheckEvaluator")
  aiGenerationSessions AiGenerationSession[]
  libraryAssets        LibraryAsset[]
}

enum LibraryAssetScope {
  personal
  shared
}

model LibraryAsset {
  id                String                  @id @default(cuid())
  title             String
  description       String                  @db.Text
  scope             LibraryAssetScope       @default(shared)
  createdById       String
  kind              AiSourceAssetKind
  filename          String?
  mimeType          String?
  fileSizeBytes     Int?
  blobUrl           String?
  includeRecording  Boolean                 @default(true)
  extractedText     String?                 @db.Text
  transcript        String?                 @db.Text
  summary           String?                 @db.Text
  durationSeconds   Int?
  muxAssetId        String?
  muxPlaybackId     String?
  processingStatus  AiAssetProcessingStatus @default(pending)
  processingError   String?                 @db.Text
  sourceCourseId    String?
  sourceCourseItemId String?
  archived          Boolean                 @default(false)
  archivedAt        DateTime?
  createdAt         DateTime                @default(now())
  updatedAt         DateTime                @updatedAt

  createdBy User @relation(fields: [createdById], references: [id], onDelete: Cascade)
  tags      LibraryAssetTag[]

  @@index([createdById])
  @@index([scope, archived])
  @@index([sourceCourseItemId])
  @@index([sourceCourseId])
}

model LibraryTag {
  id        String   @id @default(cuid())
  name      String   @unique
  slug      String   @unique
  color     String?
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  assets LibraryAssetTag[]
}

model LibraryAssetTag {
  assetId String
  tagId   String

  asset LibraryAsset @relation(fields: [assetId], references: [id], onDelete: Cascade)
  tag   LibraryTag   @relation(fields: [tagId], references: [id], onDelete: Cascade)

  @@id([assetId, tagId])
  @@index([tagId])
}

enum AiGenerationMode {
  course
  module
  lesson
}

enum AiSessionStatus {
  collecting
  processing
  generating
  structure_ready
  generating_content
  ready
  applied
  failed
}

enum AiSourceAssetKind {
  pdf
  pptx
  text
  audio
  video
  image
  embed
  webpage
}

enum AiAssetProcessingStatus {
  pending
  processing
  ready
  failed
}

model AiGenerationSession {
  id             String            @id @default(cuid())
  courseId       String
  createdById    String
  mode           AiGenerationMode
  targetModuleId String?
  status         AiSessionStatus   @default(collecting)
  userPrompt          String?           @db.Text
  blueprintJson       Json?
  generationMessages  Json?
  contentItemCursor   Int               @default(0)
  structureApproved   Boolean           @default(false)
  allowedItemTypes    Json              @default("[\"LESSON\",\"QUIZ\",\"EXAM\",\"VIDEO\"]")
  error               String?           @db.Text
  createdAt           DateTime          @default(now())
  updatedAt           DateTime          @updatedAt

  course    Course          @relation(fields: [courseId], references: [id], onDelete: Cascade)
  createdBy User            @relation(fields: [createdById], references: [id], onDelete: Cascade)
  assets    AiSourceAsset[]
}

model AiSourceAsset {
  id                String                  @id @default(cuid())
  sessionId         String
  libraryAssetId    String?
  kind              AiSourceAssetKind
  filename          String?
  mimeType          String?
  blobUrl           String?
  placementHint     String?                 @db.Text
  includeRecording  Boolean                 @default(true)
  extractedText     String?                 @db.Text
  transcript        String?                 @db.Text
  summary           String?                 @db.Text
  durationSeconds   Int?
  muxAssetId        String?
  muxPlaybackId     String?
  processingStatus  AiAssetProcessingStatus @default(pending)
  processingError   String?                 @db.Text
  sortOrder         Int                     @default(0)
  createdAt         DateTime                @default(now())

  session AiGenerationSession @relation(fields: [sessionId], references: [id], onDelete: Cascade)

  @@index([sessionId])
}

model Account {
  id                String  @id @default(cuid())
  userId            String
  type              String
  provider          String
  providerAccountId String
  refresh_token     String? @db.Text
  access_token      String? @db.Text
  expires_at        Int?
  token_type        String?
  scope             String?
  id_token          String? @db.Text
  session_state     String?

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([provider, providerAccountId])
}

model Session {
  id           String   @id @default(cuid())
  sessionToken String   @unique
  userId       String
  expires      DateTime
  user         User     @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model VerificationToken {
  identifier String
  token      String   @unique
  expires    DateTime

  @@unique([identifier, token])
}

model Invite {
  id          String    @id @default(cuid())
  email       String?
  token       String    @unique
  openSignup  Boolean   @default(false)
  label       String?
  maxUses     Int?
  useCount    Int       @default(0)
  expiresAt   DateTime
  usedAt      DateTime?
  createdAt   DateTime  @default(now())
  createdById String?
  createdBy   User?     @relation("InviteCreator", fields: [createdById], references: [id])
}

model Course {
  id                    String           @id @default(cuid())
  slug                  String           @unique
  title                 String
  description           String           @db.Text
  shortDescription      String?          @db.Text
  category              String
  estimatedHours        Float
  estimatedMinutes      Int?
  difficulty            CourseDifficulty @default(BEGINNER)
  thumbnailUrl          String?
  tags                  String[]         @default([])
  internalNotes         String?          @db.Text
  status                CourseStatus     @default(DRAFT)
  hasUnpublishedChanges Boolean          @default(false)
  publishedAt           DateTime?
  requiredRoles         String[]         @default([])
  published             Boolean          @default(true)
  archived              Boolean          @default(false)
  archivedAt            DateTime?
  createdById           String?
  createdAt             DateTime         @default(now())
  updatedAt             DateTime         @updatedAt

  createdBy              User?                      @relation("CourseCreator", fields: [createdById], references: [id])
  modules                Module[]
  courseItems            CourseItem[]
  settings               CourseSettings?
  enrollments            Enrollment[]
  enrollmentAssignments  CourseEnrollmentAssignment[]
  certificationRules     CertificationRule[]
  courseAssignments      CourseAssignment[]
  courseAdmins           CourseAdmin[]
  exams                  Exam[]
  aiGenerationSessions AiGenerationSession[]
}

model CourseAdmin {
  id        String   @id @default(cuid())
  userId    String
  courseId  String
  createdAt DateTime @default(now())
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  course    Course   @relation(fields: [courseId], references: [id], onDelete: Cascade)

  @@unique([userId, courseId])
}

model CourseAssignment {
  id       String  @id @default(cuid())
  courseId String
  jobRole  String?
  course   Course  @relation(fields: [courseId], references: [id], onDelete: Cascade)

  @@unique([courseId, jobRole])
}

model Module {
  id               String           @id @default(cuid())
  courseId         String
  title            String
  description      String?          @db.Text
  sortOrder        Int              @default(0)
  estimatedMinutes Int?
  isRequired       Boolean          @default(true)
  unlockRule       ModuleUnlockRule @default(ALWAYS)
  status           ContentStatus    @default(PUBLISHED)
  course           Course           @relation(fields: [courseId], references: [id], onDelete: Cascade)
  lessons          Lesson[]
  courseItems      CourseItem[]
}

model Lesson {
  id              String     @id @default(cuid())
  moduleId        String
  slug            String
  title           String
  type            LessonType
  sortOrder       Int        @default(0)
  durationMinutes Int?
  archived        Boolean    @default(false)
  archivedAt      DateTime?
  module          Module     @relation(fields: [moduleId], references: [id], onDelete: Cascade)
  videoAsset      VideoAsset?
  manualAsset     ManualAsset?
  exam            Exam?
  progress        LessonProgress[]
  courseItem      CourseItem? @relation("LegacyLesson")

  @@unique([moduleId, slug])
}

model CourseItem {
  id               String          @id @default(cuid())
  courseId         String
  moduleId         String
  itemType         CourseItemType
  title            String
  sortOrder        Int             @default(0)
  isRequired       Boolean         @default(true)
  estimatedMinutes Int?
  completionRule   String          @default("manual")
  status           ContentStatus   @default(DRAFT)
  track            CourseItemTrack @default(LEARN)
  legacyLessonId   String?         @unique
  lessonContentId  String?         @unique
  videoLessonId    String?         @unique
  examId           String?         @unique
  skillCheckId     String?         @unique
  scenarioId       String?         @unique
  archived         Boolean         @default(false)
  archivedAt       DateTime?
  createdAt        DateTime        @default(now())
  updatedAt        DateTime        @updatedAt

  course         Course         @relation(fields: [courseId], references: [id], onDelete: Cascade)
  module         Module         @relation(fields: [moduleId], references: [id], onDelete: Cascade)
  legacyLesson   Lesson?        @relation("LegacyLesson", fields: [legacyLessonId], references: [id], onDelete: SetNull)
  lessonContent  LessonContent? @relation(fields: [lessonContentId], references: [id], onDelete: SetNull)
  videoLesson    VideoLesson?   @relation(fields: [videoLessonId], references: [id], onDelete: SetNull)
  exam           Exam?          @relation("CourseItemExam", fields: [examId], references: [id], onDelete: SetNull)
  skillCheck     SkillCheck?    @relation(fields: [skillCheckId], references: [id], onDelete: SetNull)
  scenario       Scenario?      @relation(fields: [scenarioId], references: [id], onDelete: SetNull)
  progress       CourseItemProgress[]

  @@index([moduleId, sortOrder])
  @@index([courseId])
}

model LessonContent {
  id                  String   @id @default(cuid())
  bodyJson            Json?
  bodyHtml            String?  @db.Text
  completionRule      String   @default("viewed")
  minimumTimeSeconds  Int?
  courseItem          CourseItem?
}

model VideoLesson {
  id                    String   @id @default(cuid())
  videoUrl              String?
  muxAssetId            String?
  muxPlaybackId         String?
  durationSeconds       Int?
  transcript            String?  @db.Text
  requiredWatchPercent  Int      @default(80)
  completionRule        String   @default("watch_percent")
  status                String   @default("pending")
  courseItem            CourseItem?
}

model SkillCheck {
  id                    String              @id @default(cuid())
  traineeInstructions   String?             @db.Text
  evaluatorInstructions String?             @db.Text
  passingRule           SkillCheckPassingRule @default(ALL_REQUIRED)
  minimumScore          Int?
  requiresEvaluator     Boolean             @default(true)
  steps                 SkillCheckStep[]
  courseItem            CourseItem?
  completions           SkillCheckCompletion[]
}

model SkillCheckStep {
  id           String     @id @default(cuid())
  skillCheckId String
  text         String
  isRequired   Boolean    @default(true)
  points       Int        @default(1)
  sortOrder    Int        @default(0)
  skillCheck   SkillCheck @relation(fields: [skillCheckId], references: [id], onDelete: Cascade)
}

model SkillCheckCompletion {
  id           String               @id @default(cuid())
  skillCheckId String
  userId       String
  passed       Boolean
  score        Int?
  notes        String?              @db.Text
  evaluatedById String?
  completedAt  DateTime             @default(now())
  skillCheck   SkillCheck           @relation(fields: [skillCheckId], references: [id], onDelete: Cascade)
  user         User                 @relation(fields: [userId], references: [id], onDelete: Cascade)
  evaluatedBy  User?                @relation("SkillCheckEvaluator", fields: [evaluatedById], references: [id])

  @@unique([skillCheckId, userId])
}

model Scenario {
  id             String   @id @default(cuid())
  prompt         String   @db.Text
  backgroundInfo String?  @db.Text
  difficulty     String?
  category       String?
  courseItem     CourseItem?
}

model CourseSettings {
  id                      String           @id @default(cuid())
  courseId                String           @unique
  visibility              CourseVisibility @default(PRIVATE)
  enrollmentMode          EnrollmentMode   @default(MANUAL)
  dueDateType             CourseDueDateType @default(NONE)
  dueDaysAfterEnrollment  Int?
  fixedDueDate            DateTime?
  requireAllLessons       Boolean          @default(true)
  requireAllQuizzes       Boolean          @default(true)
  requireAllSkillChecks   Boolean          @default(true)
  finalExamRequired       Boolean          @default(false)
  finalExamPassingScore   Int?
  issueCertificate        Boolean          @default(true)
  notifyOnAssign          Boolean          @default(true)
  notifyReminder          Boolean          @default(false)
  course                  Course           @relation(fields: [courseId], references: [id], onDelete: Cascade)
}

model CourseEnrollmentAssignment {
  id           String          @id @default(cuid())
  courseId     String
  assignedById String?
  assignToType AssignToType
  assignToId   String?
  dueDateType  CourseDueDateType @default(NONE)
  dueDays      Int?
  dueDate      DateTime?
  createdAt    DateTime        @default(now())
  course       Course          @relation(fields: [courseId], references: [id], onDelete: Cascade)

  @@index([courseId])
}

model CourseItemProgress {
  id             String               @id @default(cuid())
  userId         String
  courseItemId   String
  status         LessonProgressStatus @default(NOT_STARTED)
  watchedSeconds Int                  @default(0)
  metadata       Json?
  updatedAt      DateTime             @updatedAt
  user           User                 @relation(fields: [userId], references: [id], onDelete: Cascade)
  courseItem     CourseItem           @relation(fields: [courseItemId], references: [id], onDelete: Cascade)

  @@unique([userId, courseItemId])
}

model VideoAsset {
  id              String   @id @default(cuid())
  lessonId        String   @unique
  muxAssetId      String?
  muxPlaybackId   String?
  durationSeconds Int?
  status          String   @default("pending")
  lesson          Lesson   @relation(fields: [lessonId], references: [id], onDelete: Cascade)
}

model ManualAsset {
  id        String   @id @default(cuid())
  lessonId  String?  @unique
  title     String
  category  String
  version   String
  blobUrl   String?
  filename  String?
  pageCount Int      @default(0)
  archived  Boolean  @default(false)
  archivedAt DateTime?
  updatedAt DateTime @default(now())
  lesson    Lesson?  @relation(fields: [lessonId], references: [id], onDelete: SetNull)
}

model Enrollment {
  id        String   @id @default(cuid())
  userId    String
  courseId  String
  createdAt DateTime @default(now())
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  course    Course   @relation(fields: [courseId], references: [id], onDelete: Cascade)

  @@unique([userId, courseId])
}

model LessonProgress {
  id              String               @id @default(cuid())
  userId          String
  lessonId        String
  status          LessonProgressStatus @default(NOT_STARTED)
  watchedSeconds  Int                  @default(0)
  updatedAt       DateTime             @updatedAt
  user            User                 @relation(fields: [userId], references: [id], onDelete: Cascade)
  lesson          Lesson               @relation(fields: [lessonId], references: [id], onDelete: Cascade)

  @@unique([userId, lessonId])
}

model Exam {
  id                String          @id @default(cuid())
  title             String
  description       String?         @db.Text
  lessonId          String?         @unique
  courseId          String?
  createdById       String?
  passingScore      Int
  timeLimitMinutes  Int
  attemptsAllowed   Int             @default(3)
  shuffleQuestions  Boolean         @default(false)
  published         Boolean         @default(true)
  archived          Boolean         @default(false)
  archivedAt        DateTime?
  gradeVisibility   GradeVisibility @default(ADMIN_ONLY)
  gradesPublishedAt DateTime?
  createdAt         DateTime        @default(now())
  updatedAt         DateTime        @updatedAt

  lesson      Lesson?          @relation(fields: [lessonId], references: [id], onDelete: Cascade)
  course      Course?          @relation(fields: [courseId], references: [id], onDelete: SetNull)
  courseItem  CourseItem?      @relation("CourseItemExam")
  createdBy   User?            @relation("ExamCreator", fields: [createdById], references: [id])
  questions   Question[]
  attempts    ExamAttempt[]
  assignments ExamAssignment[]
  graders     ExamGrader[]
}

model ExamAssignment {
  id        String   @id @default(cuid())
  examId    String
  userId    String
  createdAt DateTime @default(now())
  exam      Exam     @relation(fields: [examId], references: [id], onDelete: Cascade)
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([examId, userId])
}

model ExamGrader {
  id        String   @id @default(cuid())
  examId    String
  userId    String
  createdAt DateTime @default(now())
  exam      Exam     @relation(fields: [examId], references: [id], onDelete: Cascade)
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([examId, userId])
}

model Question {
  id        String       @id @default(cuid())
  examId    String
  type      QuestionType @default(MULTIPLE_CHOICE)
  text      String       @db.Text
  sortOrder Int          @default(0)
  config    Json?
  exam      Exam         @relation(fields: [examId], references: [id], onDelete: Cascade)
  options   AnswerOption[]
  answers   ExamAnswer[]
  gradingTasks GradingTask[]
}

model AnswerOption {
  id         String   @id @default(cuid())
  questionId String
  text       String
  isCorrect  Boolean  @default(false)
  sortOrder  Int      @default(0)
  question   Question @relation(fields: [questionId], references: [id], onDelete: Cascade)
}

model ExamAttempt {
  id                  String            @id @default(cuid())
  userId              String
  examId              String
  score               Int?
  passed              Boolean?
  status              ExamAttemptStatus @default(IN_PROGRESS)
  pendingManualGrade  Boolean           @default(false)
  questionOrder       Json?
  startedAt           DateTime          @default(now())
  completedAt         DateTime?
  answers             Json?
  user                User              @relation(fields: [userId], references: [id], onDelete: Cascade)
  exam                Exam              @relation(fields: [examId], references: [id], onDelete: Cascade)
  examAnswers         ExamAnswer[]
  gradingTasks        GradingTask[]
}

model ExamAnswer {
  id           String    @id @default(cuid())
  attemptId    String
  questionId   String
  value        Json
  autoScore    Float?
  manualScore  Float?
  feedback     String?   @db.Text
  gradedById   String?
  gradedAt     DateTime?
  attempt      ExamAttempt @relation(fields: [attemptId], references: [id], onDelete: Cascade)
  question     Question    @relation(fields: [questionId], references: [id], onDelete: Cascade)
  gradedBy     User?       @relation("GradedBy", fields: [gradedById], references: [id])

  @@unique([attemptId, questionId])
}

model GradingTask {
  id               String            @id @default(cuid())
  attemptId        String
  questionId       String
  courseId         String?
  status           GradingTaskStatus @default(PENDING)
  assignedToUserId String?
  archived         Boolean           @default(false)
  archivedAt       DateTime?
  createdAt        DateTime          @default(now())
  completedAt      DateTime?
  attempt          ExamAttempt       @relation(fields: [attemptId], references: [id], onDelete: Cascade)
  question         Question          @relation(fields: [questionId], references: [id], onDelete: Cascade)
  assignedTo       User?             @relation("GradingAssignee", fields: [assignedToUserId], references: [id])

  @@unique([attemptId, questionId])
}

model Notification {
  id        String           @id @default(cuid())
  userId    String
  type      NotificationType
  title     String
  body      String           @db.Text
  link      String?
  readAt    DateTime?
  metadata  Json?
  createdAt DateTime         @default(now())
  user      User             @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model CertificationRule {
  id             String          @id @default(cuid())
  courseId       String
  title          String
  validityMonths Int             @default(12)
  archived       Boolean         @default(false)
  archivedAt     DateTime?
  course         Course          @relation(fields: [courseId], references: [id], onDelete: Cascade)
  certifications Certification[]
}

model Certification {
  id        String              @id @default(cuid())
  userId    String
  ruleId    String
  title     String
  status    CertificationStatus @default(IN_PROGRESS)
  issuedAt  DateTime?
  expiresAt DateTime?
  user      User                @relation(fields: [userId], references: [id], onDelete: Cascade)
  rule      CertificationRule   @relation(fields: [ruleId], references: [id], onDelete: Cascade)

  @@unique([userId, ruleId])
}
